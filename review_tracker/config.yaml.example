# ============================================================
# 亚马逊评论追踪系统 - 配置文件
# 复制此文件为 config.yaml 并填入真实信息
# ============================================================

# ---------- 邮件配置 ----------
email:
  smtp_host: smtp.qq.com
  smtp_port: 587
  sender: your_email@qq.com
  password: your_smtp_app_password
  recipient: recipient@example.com

# ---------- 抓取配置 ----------
scraper:
  request_interval_min: 3
  request_interval_max: 6
  timeout: 15
  max_retries: 3
  language: en_US

# ---------- 要跟踪的产品列表 ----------
products:
  - url: https://www.amazon.com/dp/B0XXXXXXXX
  - url: https://www.amazon.com/dp/B0XXXXXXXX
