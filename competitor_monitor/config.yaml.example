# ============================================================
# 竞品监控 - 配置文件
# 复制此文件为 config.yaml 并填入真实信息
# ============================================================

# 要监控的 ASIN 列表（按 Excel 列顺序排列）
asins:
  - B0XXXXXXXX
  - B0XXXXXXXX

# 抓取配置（加大间隔避免反爬）
scraper:
  interval_min: 5
  interval_max: 10
  timeout: 20
  max_retries: 3

# Excel 输出目录
output_dir: outputs
